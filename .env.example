APP_ENV=development
APP_BASE_URL=http://localhost:8000

SECRET_KEY=replace-with-32-plus-char-secret
JWT_SECRET=replace-with-32-plus-char-jwt-secret

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/email_campaign
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/email_campaign
REDIS_URL=redis://localhost:6379/0

AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1
AWS_S3_BUCKET=email-campaign-assets
AWS_SQS_SEND_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/email-send
AWS_SQS_EVENTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/email-events
AWS_SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789012/email-send-dlq
AWS_SES_CONFIG_SET=email-campaign-config-set

ALLOWED_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

MAX_SES_SEND_RATE=14
SQS_POLL_WAIT_SECONDS=20
SQS_MAX_MESSAGES=10
WORKER_CONCURRENCY=5
WORKER_MAX_RETRIES=5

RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_TEST_EMAIL_PER_HOUR=10
RATE_LIMIT_WEBHOOK_PER_MINUTE=60

LOG_LEVEL=INFO
LOG_FORMAT_JSON=false
REQUEST_TIMEOUT_SECONDS=30
ENABLE_HEALTHCHECKS=true
ENABLE_METRICS=true
